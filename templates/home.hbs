<div class="max-w-5xl mx-auto px-4 sm:px-6 lg:px-8 py-16">
  
  <!-- Hero Section -->
  <section class="mb-24 relative rounded-[2rem] overflow-hidden border border-border-subtle bg-bg-card shadow-2xl">
    <div class="absolute inset-0 bg-gradient-to-br from-[var(--hero-glow-1)] via-transparent to-[var(--hero-glow-2)] pointer-events-none"></div>
    
    <div class="p-8 md:p-14 md:flex gap-12 items-center relative z-10">
      {{#if site.image}}
      <div class="shrink-0 mb-10 md:mb-0 relative group">
        <div class="absolute -inset-1 bg-gradient-to-r from-brand-primary to-brand-secondary rounded-[2rem] blur opacity-25 group-hover:opacity-50 transition duration-1000 group-hover:duration-200"></div>
        <img src="{{site.image}}" alt="Podcast Cover" class="relative w-56 h-56 md:w-72 md:h-72 rounded-3xl object-cover ring-1 ring-[var(--glass-border)]" />
      </div>
      {{/if}}
      
      <div>
        <h2 class="font-['Outfit'] text-4xl md:text-6xl lg:text-7xl font-black tracking-tighter text-text-main mb-6 leading-[1.1]">{{site.title}}</h2>
        <p class="text-lg md:text-xl text-text-muted leading-relaxed font-light max-w-2xl">{{site.description}}</p>
      </div>
    </div>
  </section>

  <!-- Episodes List -->
  <section>
    <div class="flex items-center justify-between mb-12">
      <h3 class="font-['Outfit'] text-3xl md:text-4xl font-bold text-text-main tracking-tight flex items-center gap-4" data-t="latest_episodes">
        Latest Episodes
      </h3>
    </div>
    
    <div class="grid gap-6">
      {{#each episodes}}
      <article class="bg-bg-card rounded-3xl border border-border-subtle p-6 md:p-8 hover:border-brand-primary/50 transition-all duration-500 group relative overflow-hidden flex flex-col md:flex-row gap-8 items-start hover:shadow-2xl">
        
        <!-- Hover highlight line -->
        <div class="absolute top-0 left-0 w-1.5 h-full bg-gradient-to-b from-brand-primary to-brand-secondary opacity-0 group-hover:opacity-100 transition-opacity duration-300"></div>
        
        <div class="flex-1 w-full pl-2">
          <div class="flex flex-wrap items-center gap-3 text-xs text-brand-primary-text mb-4 font-semibold tracking-widest uppercase">
            <time datetime="{{this.pubDate}}" data-date="{{this.pubDate}}">{{this.pubDate}}</time>
            {{#if this.itunes.duration}}
            <span class="text-text-muted/40">&bull;</span>
            <span class="text-text-muted">{{this.itunes.duration}}</span>
            {{/if}}
          </div>
          
          <div class="flex flex-col md:flex-row gap-6 mb-8 w-full">
            <div class="flex-1">
              <a href="/episode/{{this.id}}/" class="block mb-4">
                <h4 class="font-['Outfit'] text-2xl md:text-3xl font-bold text-text-main group-hover:text-brand-primary transition-colors leading-tight tracking-tight">
                  {{this.title}}
                </h4>
              </a>
              <p class="text-text-muted line-clamp-2 md:line-clamp-3 leading-relaxed font-light text-[15px] max-w-4xl">
                {{this.contentSnippet}}
              </p>
            </div>
            
            {{#if this.image}}
            <a href="/episode/{{this.id}}/" class="shrink-0 block relative w-24 h-24 sm:w-32 sm:h-32 md:w-48 md:h-48 lg:w-[200px] lg:h-[200px] rounded-2xl overflow-hidden border border-border-subtle group-hover:border-brand-primary/30 transition-colors bg-black/5">
              <img src="{{this.image}}" alt="{{this.title}}" class="absolute inset-0 w-full h-full object-cover rounded-2xl group-hover:scale-105 transition-transform duration-700">
            </a>
            {{/if}}
          </div>
          
          <div class="flex flex-col sm:flex-row sm:items-center gap-6 w-full mt-auto">
            {{#if this.enclosure.url}}
            <div class="flex-1 w-full max-w-md bg-[var(--btn-bg)] rounded-[2rem] p-2 border border-border-subtle shadow-inner">
              <div class="custom-audio-wrapper w-full flex items-center gap-3">
                <button class="play-pause-btn shrink-0 w-10 h-10 rounded-full bg-gradient-to-br from-brand-primary to-brand-secondary flex items-center justify-center shadow flex-shrink-0 hover:scale-105 active:scale-95 transition-all text-black hover:shadow-brand-primary/50" aria-label="Play">
                  <svg class="play-icon w-4 h-4 ml-0.5" fill="currentColor" viewBox="0 0 24 24"><path d="M8 5v14l11-7z"/></svg>
                  <svg class="pause-icon w-4 h-4 hidden" fill="currentColor" viewBox="0 0 24 24"><path d="M6 19h4V5H6v14zm8-14v14h4V5h-4z"/></svg>
                </button>
                <div class="flex-1 flex flex-col gap-1 pr-3 mt-0.5">
                  <div class="flex justify-between text-[10px] text-text-muted font-medium font-mono leading-none">
                    <span class="time-current">0:00</span>
                    <span class="time-total">0:00</span>
                  </div>
                  <div class="progress-bg relative w-full h-1.5 rounded-full bg-border-subtle cursor-pointer hover:h-2 transition-all">
                    <div class="progress-fg absolute left-0 top-0 h-full rounded-full bg-brand-primary pointer-events-none w-0"></div>
                  </div>
                </div>
                <audio class="hidden-audio" src="{{this.enclosure.url}}" preload="metadata"></audio>
              </div>
            </div>
            {{/if}}
            <a href="/episode/{{this.id}}/" class="shrink-0 inline-flex items-center justify-center gap-2 px-6 py-3 rounded-full bg-[var(--btn-bg)] hover:bg-[var(--btn-hover-border)] text-text-main text-sm font-semibold transition-all duration-300 border border-[var(--btn-border)] hover:border-brand-primary/50 hover:scale-105 active:scale-95 group/btn">
              <span data-t="explore">Explore</span> 
              <svg class="w-4 h-4 group-hover/btn:translate-x-1 transition-transform" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2.5" d="M14 5l7 7m0 0l-7 7m7-7H3"></path></svg>
            </a>
          </div>
        </div>
      </article>
      {{/each}}
    </div>
  </section>
</div>
